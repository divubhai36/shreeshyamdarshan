generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  imageUrl      String
  videos        String[]       @default([])
  subCategories SubCategory[]
  products      Product[]
  createdAt     DateTime       @default(now())
}


model SubCategory {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  imageUrl          String
  categoryId        String
  category          Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  innerSubCategories InnerSubCategory[]
  products          Product[]
}

model InnerSubCategory {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  imageUrl      String
  subCategoryId String
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  products      Product[]
}

model Product {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  description       String
  mrp               Float
  price             Float
  discountPercent   Int?
  offerPrice        Float?
  images            String[]
  videos            String[]
  details           Json?
  isBestSeller      Boolean           @default(false)
  isOfferProduct    Boolean           @default(false)
  isReadyStock      Boolean           @default(false)
  showSizeGuide     Boolean           @default(false)
  showWashCare      Boolean           @default(false)
  
  wholesalerDescription String?
  variants          Json?             // Array of objects: { name: string, price: number }
  unit              String            @default("PIECE") // PIECE | DOZEN
  isVisible         Boolean           @default(true)
  allowToBuy        Boolean           @default(true)

  productId         String            @unique
  categoryId        String
  category          Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subCategoryId     String
  subCategory       SubCategory       @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  innerSubId        String?
  innerSubCategory  InnerSubCategory? @relation(fields: [innerSubId], references: [id])
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  orderItems        OrderItem[]
  savedBy           SavedProduct[]
  cartItems         CartItem[]
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Wholesaler {
  id            String         @id @default(cuid())
  name          String
  email         String?        @unique
  password      String
  plainPassword String?
  companyName   String?
  phone         String         @unique
  address       String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orders        Order[]
  savedProducts SavedProduct[]
  cartItems     CartItem[]
  review        Review?
}

model CartItem {
  id           String     @id @default(cuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity     Int
  variantName  String     @default("BASE")
  price        Float      @default(0)
  originalPrice Float?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([wholesalerId, productId, variantName])
}

enum OrderStatus {
  PENDING
  APPROVED
  DISPATCHED
  COMPLETED
  CANCELLED
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  wholesalerId  String
  wholesaler    Wholesaler  @relation(fields: [wholesalerId], references: [id])
  totalAmount   Float
  originalTotal Float       @default(0)
  status        OrderStatus @default(PENDING)
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  originalPrice Float?
  variantName String?
}

model SavedProduct {
  id           String     @id @default(cuid())
  wholesalerId String
  wholesaler   Wholesaler @relation(fields: [wholesalerId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantName  String     @default("BASE")
  createdAt    DateTime   @default(now())

  @@unique([wholesalerId, productId, variantName])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Review {
  id           String       @id @default(cuid())
  wholesalerId String?      @unique
  wholesaler   Wholesaler?  @relation(fields: [wholesalerId], references: [id], onDelete: Cascade)
  rating       Int          @default(5)
  comment      String
  status       ReviewStatus @default(PENDING)
  dummyName    String?      // For admin dummy reviews
  dummyCompany String?      // For admin dummy reviews
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}
